// Strategy: XAUUSD-FVG-V2.0
// 多 FVG 追蹤版 — 模擬 Nephew_Sam_ 視覺概念 + 策略進出場
// V2.0: 單一 FVG 升級為陣列追蹤，支援多 FVG 同時顯示、Wick/Close 填滿模式

//@version=6
strategy(title="XAUUSD-FVG-V2.0",
 shorttitle="FVG-V2",
 overlay=true,
 format=format.price,
 precision=2,
 default_qty_type=strategy.cash,
 initial_capital=10000,
 default_qty_value=10000,
 commission_value=0.00,
 slippage=1)

strategy.cancel_all()
MP = strategy.position_size > 0 ? 1 : strategy.position_size < 0 ? -1 : 0

//------------------------------------------------------------------------------
// 1. 前置設定與輸入 (Inputs)
//------------------------------------------------------------------------------

grp_dir = "=== 交易方向 ==="
direction = input.string("Long", "方向 (Long / Short)", options=["Long","Short"], group=grp_dir)

grp_fvg = "=== FVG 設定 ==="
fvg_min_pct  = input.float(0.20, "最小 FVG 大小 (%)", step=0.01, minval=0.01, group=grp_fvg,
    tooltip="過濾太小的缺口，建議 0.05–0.20%（黃金 30m）\n回測最佳（Long）: 0.20%")
fvg_max_bars = input.int(20, "FVG 最長有效 K 棒數", minval=5, maxval=300, group=grp_fvg,
    tooltip="超過此 K 棒數未觸及，FVG 自動到期刪除\n回測最佳（Long）: 20 bars")
max_fvg      = input.int(5, "最多同時追蹤 FVG 數", minval=1, maxval=20, group=grp_fvg,
    tooltip="超過上限時，最舊的 FVG 自動淘汰（仿 Nephew_Sam_ 行為）")
fill_mode    = input.string("Wick", "FVG 填滿判斷模式",
    options=["Wick", "Close"], group=grp_fvg,
    tooltip="Wick: 影線穿越 FVG 邊界即視為填滿（較靈敏）\nClose: 收盤穿越才算填滿（較保守）")

grp_sl = "=== 止損設定 ==="
sl_type   = input.string("Fixed %", "止損方式",
    options=["FVG Natural", "Fixed %"], group=grp_sl,
    tooltip="Fixed %: 回測最佳（0.8%）\nFVG Natural: SL 設在 FVG 邊界外")
sl_pct    = input.float(1.5, "固定止損 % (Fixed 模式)", step=0.1, minval=0.1, group=grp_sl)
sl_buffer = input.float(0.05, "FVG 邊界緩衝 % (Natural 模式)", step=0.01, group=grp_sl)

grp_tp = "=== 獲利設定 ==="
tp1_r = input.float(0.5, "TP1 R 倍數", step=0.1, minval=0.1, group=grp_tp,
    tooltip="回測最佳：0.5R（快速鎖利）")
tp2_r = input.float(2.0, "TP2 R 倍數", step=0.1, minval=0.5, group=grp_tp)
tb    = input.int(72, "時間止損 K 棒數", minval=4, group=grp_tp)

grp_f = "=== 過濾器 (可選) ==="
use_rsi      = input.bool(false, "啟用 RSI 過濾", group=grp_f)
rsi_len      = input.int(14, "RSI 週期", group=grp_f)
rsi_bull_min = input.int(40, "多單 RSI 最低門檻", group=grp_f)
rsi_bear_max = input.int(60, "空單 RSI 最高門檻", group=grp_f)
use_htf      = input.bool(false, "啟用 4H EMA 過濾", group=grp_f)
htf_len      = input.int(21, "4H EMA 長度", group=grp_f)

grp_v = "=== 視覺化 ==="
show_labels   = input.bool(true,  "顯示進場標籤", group=grp_v)
show_size_lbl = input.bool(true,  "顯示 FVG 大小 (%)", group=grp_v)
clr_bull      = input.color(color.new(color.green, 80), "多頭 FVG 顏色", group=grp_v)
clr_bear      = input.color(color.new(color.red,   80), "空頭 FVG 顏色", group=grp_v)

grp_fut = "=== 期貨對應 ==="
show_fut = input.bool(true, "顯示 GC1! 對應", group=grp_fut)
fut_sym  = input.symbol("COMEX:GC1!", "期貨代碼", group=grp_fut)

//------------------------------------------------------------------------------
// 2. 指標計算 (Indicators)
//------------------------------------------------------------------------------
is_long = direction == "Long"

rsi_val = ta.rsi(close, rsi_len)
htf_ema = request.security(syminfo.tickerid, "240",
    ta.ema(close, htf_len), lookahead=barmerge.lookahead_off)
fut_cls = request.security(fut_sym, timeframe.period, close)
basis   = fut_cls - close

rsi_ok    = not use_rsi or (is_long ? rsi_val > rsi_bull_min : rsi_val < rsi_bear_max)
htf_ok    = not use_htf or (is_long ? close > htf_ema        : close < htf_ema)
filter_ok = rsi_ok and htf_ok

//------------------------------------------------------------------------------
// 3. FVG 陣列狀態 (V2 核心)
//------------------------------------------------------------------------------
// 每個 FVG 同時維護四個陣列（同 index = 同一個 FVG）
var float[] fvg_tops  = array.new<float>()   // FVG 頂
var float[] fvg_bots  = array.new<float>()   // FVG 底
var int[]   fvg_bars  = array.new<int>()     // 形成時的 bar_index
var box[]   fvg_boxes = array.new<box>()     // 對應的色塊物件

// 進場時鎖定的 FVG 邊界，供出場計算
var float locked_bot = na
var float locked_top = na

//------------------------------------------------------------------------------
// 4. FVG 陣列更新：移除到期 / 已填滿的 FVG
//    (逆序迭代，安全刪除)
//------------------------------------------------------------------------------
if array.size(fvg_tops) > 0
    for i = array.size(fvg_tops) - 1 to 0
        t  = array.get(fvg_tops, i)
        bv = array.get(fvg_bots, i)
        bi = array.get(fvg_bars, i)

        expired = (bar_index - bi) > fvg_max_bars

        // 填滿判斷（多頭 FVG：價格跌破底部；空頭 FVG：價格升破頂部）
        filled = false
        if fill_mode == "Wick"
            filled := is_long ? low < bv : high > t
        else
            filled := is_long ? close < bv : close > t

        if expired or filled
            bx = array.remove(fvg_boxes, i)
            box.delete(bx)
            array.remove(fvg_tops, i)
            array.remove(fvg_bots, i)
            array.remove(fvg_bars, i)

//------------------------------------------------------------------------------
// 5. 偵測新 FVG 並加入陣列
//------------------------------------------------------------------------------
// Bullish FVG: low[0] > high[2]  → 向上跳空缺口，等回踩進多
bull_fvg_raw = low > high[2]
bull_fvg_top = low
bull_fvg_bot = high[2]

// Bearish FVG: high[0] < low[2] → 向下跳空缺口，等反彈進空
bear_fvg_raw = high < low[2]
bear_fvg_top = low[2]
bear_fvg_bot = high

bull_size    = bull_fvg_raw ? (bull_fvg_top - bull_fvg_bot) / close * 100 : 0.0
bear_size    = bear_fvg_raw ? (bear_fvg_top - bear_fvg_bot) / close * 100 : 0.0
fvg_size_pct = is_long ? bull_size : bear_size

new_fvg = (is_long ? bull_fvg_raw : bear_fvg_raw) and fvg_size_pct >= fvg_min_pct

if new_fvg
    new_top = is_long ? bull_fvg_top : bear_fvg_top
    new_bot = is_long ? bull_fvg_bot : bear_fvg_bot
    clr_bg  = is_long ? clr_bull : clr_bear
    clr_bdr = is_long ? color.new(color.green, 0) : color.new(color.red, 0)

    // 建立色塊（extend.right → 自動延伸至圖表右端，填滿/刪除時消失）
    bx = box.new(bar_index - 2, new_top, bar_index, new_bot,
        bgcolor      = clr_bg,
        border_color = clr_bdr,
        border_width = 1,
        extend       = extend.right)

    // FVG 大小標籤
    if show_size_lbl
        lbl_y   = is_long ? new_bot : new_top
        lbl_sty = is_long ? label.style_label_up : label.style_label_down
        label.new(bar_index - 1, lbl_y,
            str.tostring(fvg_size_pct, "#.##") + "%",
            style=lbl_sty,
            color=color.new(color.gray, 55),
            textcolor=color.white,
            size=size.tiny)

    array.push(fvg_tops,  new_top)
    array.push(fvg_bots,  new_bot)
    array.push(fvg_bars,  bar_index)
    array.push(fvg_boxes, bx)

    // 超過上限 → 淘汰最舊的（index 0）
    if array.size(fvg_tops) > max_fvg
        old_bx = array.remove(fvg_boxes, 0)
        box.delete(old_bx)
        array.remove(fvg_tops, 0)
        array.remove(fvg_bots, 0)
        array.remove(fvg_bars, 0)

//------------------------------------------------------------------------------
// 6. 進場訊號（從最新 FVG 往舊掃，第一個觸及即進場）
//------------------------------------------------------------------------------
LongEntry  = false
ShortEntry = false

if MP == 0 and filter_ok and array.size(fvg_tops) > 0
    for i = array.size(fvg_tops) - 1 to 0
        t  = array.get(fvg_tops, i)
        bv = array.get(fvg_bots, i)
        bi = array.get(fvg_bars, i)

        if bar_index > bi    // FVG 至少形成 1 根 K 棒前，防止 same-bar 進場
            hit = is_long ? (low <= t and close >= bv) : (high >= bv and close <= t)
            if hit
                locked_bot := bv
                locked_top := t
                // 消耗此 FVG（移除色塊，不允許同一個 FVG 重複進場）
                bx = array.remove(fvg_boxes, i)
                box.delete(bx)
                array.remove(fvg_tops, i)
                array.remove(fvg_bots, i)
                array.remove(fvg_bars, i)
                LongEntry  := is_long
                ShortEntry := not is_long
                break

if LongEntry
    strategy.entry("FVG_LE", strategy.long,  comment="FVG_LE")
if ShortEntry
    strategy.entry("FVG_SE", strategy.short, comment="FVG_SE")

//------------------------------------------------------------------------------
// 7. 出場邏輯 (Profit Flyer — 同 V1，架構自 S1-AweWithBB)
//------------------------------------------------------------------------------
ep      = strategy.opentrades.entry_price(strategy.opentrades - 1)
bars_in = bar_index - strategy.opentrades.entry_bar_index(strategy.opentrades - 1)

var float sl_price = na
if sl_type == "FVG Natural"
    if is_long
        sl_price := not na(locked_bot) ? locked_bot * (1 - sl_buffer / 100) : ep * (1 - sl_pct / 100)
    else
        sl_price := not na(locked_top) ? locked_top * (1 + sl_buffer / 100) : ep * (1 + sl_pct / 100)
else
    sl_price := is_long ? ep * (1 - sl_pct / 100) : ep * (1 + sl_pct / 100)

r_dist = math.abs(ep - sl_price)
tp1    = is_long ? ep + r_dist * tp1_r : ep - r_dist * tp1_r
tp2    = is_long ? ep + r_dist * tp2_r : ep - r_dist * tp2_r
tb4    = int(tb / 4)
tb2    = int(tb / 2)

var float exit_stop = na

// ── 多頭出場 ─────────────────────────────────────────────────────────────────
if MP > 0
    if close >= tp2
        exit_stop := math.max(tp2, ta.lowest(low, tb4))
        strategy.exit("FVG_LX_TP2", from_entry="FVG_LE", stop=exit_stop, comment="FVG_LX_TP2")
    else if close >= tp1
        exit_stop := math.max(tp1, ta.lowest(low, tb2))
        strategy.exit("FVG_LX_TP1", from_entry="FVG_LE", stop=exit_stop, comment="FVG_LX_TP1")
    else
        strategy.exit("FVG_LX_SL", from_entry="FVG_LE", stop=sl_price, comment_loss="FVG_SL")
    if bars_in >= tb
        if strategy.openprofit >= 0
            strategy.exit("FVG_LX_TW", from_entry="FVG_LE", stop=math.max(sl_price, ta.lowest(low, tb)), comment="FVG_LX_TW")
        else
            strategy.exit("FVG_LX_TL", from_entry="FVG_LE", stop=low, comment="FVG_LX_TL")

// ── 空頭出場 ─────────────────────────────────────────────────────────────────
if MP < 0
    if close <= tp2
        exit_stop := math.min(tp2, ta.highest(high, tb4))
        strategy.exit("FVG_SX_TP2", from_entry="FVG_SE", stop=exit_stop, comment="FVG_SX_TP2")
    else if close <= tp1
        exit_stop := math.min(tp1, ta.highest(high, tb2))
        strategy.exit("FVG_SX_TP1", from_entry="FVG_SE", stop=exit_stop, comment="FVG_SX_TP1")
    else
        strategy.exit("FVG_SX_SL", from_entry="FVG_SE", stop=sl_price, comment_loss="FVG_SL")
    if bars_in >= tb
        if strategy.openprofit >= 0
            strategy.exit("FVG_SX_TW", from_entry="FVG_SE", stop=math.min(sl_price, ta.highest(high, tb)), comment="FVG_SX_TW")
        else
            strategy.exit("FVG_SX_TL", from_entry="FVG_SE", stop=high, comment="FVG_SX_TL")

//------------------------------------------------------------------------------
// 8. 進場標籤 (同 V1 風格)
//------------------------------------------------------------------------------
if (LongEntry or ShortEntry) and show_labels
    sl_lbl = float(na)
    if sl_type == "FVG Natural"
        sl_lbl := LongEntry ? locked_bot * (1 - sl_buffer / 100) : locked_top * (1 + sl_buffer / 100)
    else
        sl_lbl := LongEntry ? close * (1 - sl_pct / 100) : close * (1 + sl_pct / 100)
    r_lbl   = math.abs(close - sl_lbl)
    tp1_lbl = LongEntry ? close + r_lbl * tp1_r : close - r_lbl * tp1_r
    tp2_lbl = LongEntry ? close + r_lbl * tp2_r : close - r_lbl * tp2_r

    fvg_zone = "FVG: [" + str.tostring(locked_bot, "#.##") + " - " + str.tostring(locked_top, "#.##") + "]"
    dir_lbl  = LongEntry ? "▲ FVG_LE" : "▼ FVG_SE"
    txt = dir_lbl + "\nEntry: " + str.tostring(close, "#.##") + "\nSL: " + str.tostring(sl_lbl, "#.##") + "\nTP1: " + str.tostring(tp1_lbl, "#.##") + "\nTP2: " + str.tostring(tp2_lbl, "#.##") + "\n" + fvg_zone

    if show_fut
        txt := txt + "\n[GC1!] Entry: " + str.tostring(close + basis, "#.##") + "\n       SL: " + str.tostring(sl_lbl + basis, "#.##")

    lbl_y = LongEntry ? low * 0.9995 : high * 1.0005
    label.new(bar_index, lbl_y, txt,
        style     = LongEntry ? label.style_label_up : label.style_label_down,
        color     = LongEntry ? color.blue : color.red,
        textcolor = color.white,
        size      = size.small)

//------------------------------------------------------------------------------
// 9. Alert
//------------------------------------------------------------------------------
alertcondition(LongEntry,  title="FVG Long Entry",  message="FVG_LE Buy,  Price={{close}}")
alertcondition(ShortEntry, title="FVG Short Entry", message="FVG_SE Sell, Price={{close}}")
