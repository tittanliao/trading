//@version=6
strategy("TX All Short Strategies", overlay=true, default_qty_type=strategy.fixed, default_qty_value=1,
         currency=currency.TWD, commission_type=strategy.commission.cash_per_order, commission_value=100)

strategy_id = input.string("S01 RSI Overbought Drop", "Strategy", options=["S01 RSI Overbought Drop","S02 MACD Cross Above Zero","S03 MACD Hist Reversal Short","S04 Stoch Overbought Cross","S05 Williams %R Overbought","S06 CCI Overbought Drop","S07 RSI 50 Crossdown","S08 EMA 9/21 Death Cross","S09 EMA55 Resistance","S10 Supertrend Sell","S11 Donchian 20L Break","S12 BB Squeeze Short","S13 ATR Momentum Break Short","S14 BB Upper Rejection","S15 BB High + RSI Combo","S16 Shooting Star","S17 Bearish Engulfing","S18 RSI Bearish Divergence","S19 Day Open Range Short","S20 Night Momentum Short"], group="Strategy")
sl_pts  = input.int(30, "SL Points", minval=5, group="Risk")
tp_pts  = input.int(60, "TP Points", minval=5, group="Risk")
use_day   = input.bool(true,  "日盤", group="Session")
use_night = input.bool(true,  "夜盤", group="Session")

t = time("30", "0845-1345", "Asia/Taipei")
n = time("30", "1500-0500", "Asia/Taipei")
in_session = (use_day and not na(t)) or (use_night and not na(n))

rsi        = ta.rsi(close, 14)
[macd, sig, hist] = ta.macd(close, 12, 26, 9)
[bb_upper, bb_mid, bb_lower] = ta.bb(close, 20, 2)
ema9       = ta.ema(close, 9)
ema21      = ta.ema(close, 21)
ema55      = ta.ema(close, 55)
atr        = ta.atr(14)
stoch_k    = ta.sma(ta.stoch(close, high, low, 14), 3)
stoch_d    = ta.sma(stoch_k, 3)
don_high   = ta.highest(high[1], 20)
don_low    = ta.lowest(low[1], 20)
cci        = ta.cci(close, 20)
willr      = ta.wpr(14)
bb_pct     = (close - bb_lower) / (bb_upper - bb_lower)

entry_signal = false

if strategy_id == "S01 RSI Overbought Drop"
    entry_signal = ta.crossunder(rsi, 70) and rsi > 45

if strategy_id == "S02 MACD Cross Above Zero"
    entry_signal = ta.crossunder(macd, sig) and macd > 0

if strategy_id == "S03 MACD Hist Reversal Short"
    entry_signal = hist[2] > hist[1] and hist[1] > hist and hist[2] > 0

if strategy_id == "S04 Stoch Overbought Cross"
    entry_signal = ta.crossunder(stoch_k, stoch_d) and stoch_k > 75

if strategy_id == "S05 Williams %R Overbought"
    entry_signal = ta.crossover(willr, -20)

if strategy_id == "S06 CCI Overbought Drop"
    entry_signal = ta.crossunder(cci, 100)

if strategy_id == "S07 RSI 50 Crossdown"
    entry_signal = ta.crossunder(rsi, 50) and ema21 < ema55

if strategy_id == "S08 EMA 9/21 Death Cross"
    entry_signal = ta.crossunder(ema9, ema21) and close < ema55

if strategy_id == "S09 EMA55 Resistance"
    entry_signal = math.abs(close - ema55) < atr * 0.4 and ema21 < ema55 and rsi >= 35 and rsi <= 60

if strategy_id == "S10 Supertrend Sell"
    [st_val, st_dir] = ta.supertrend(3.0, 10)
    entry_signal = ta.crossunder(close, st_val)

if strategy_id == "S11 Donchian 20L Break"
    entry_signal = close < don_low and rsi < 50

if strategy_id == "S12 BB Squeeze Short"
    bb_width = (bb_upper - bb_lower) / bb_mid
    squeeze = bb_width < ta.percentile_linear_interpolation(bb_width, 100, 20)
    entry_signal = squeeze[1] and ta.crossunder(close, bb_lower)

if strategy_id == "S13 ATR Momentum Break Short"
    low20 = ta.lowest(close[1], 20)
    entry_signal = close < low20 - atr * 0.3 and rsi < 50

if strategy_id == "S14 BB Upper Rejection"
    entry_signal = bb_pct >= 0.95 and rsi > 55 and rsi < rsi[3]

if strategy_id == "S15 BB High + RSI Combo"
    entry_signal = bb_pct > 0.80 and ta.crossunder(rsi, 70)

if strategy_id == "S16 Shooting Star"
    body = math.abs(close - open)
    upper_wick = high - math.max(open, close)
    lower_wick = math.min(open, close) - low
    entry_signal = upper_wick > body * 2 and lower_wick < body * 0.5 and body > 0 and rsi > 45

if strategy_id == "S17 Bearish Engulfing"
    entry_signal = close < open and close[1] > open[1] and open >= close[1] and close <= open[1] and rsi > 40

if strategy_id == "S18 RSI Bearish Divergence"
    // Requires RSI bearish divergence signal
    entry_signal = false  // replace with your divergence signal

if strategy_id == "S19 Day Open Range Short"
    first_bar = (hour == 8 and minute == 45)
    var float orb_low = na
    if first_bar
        orb_low := low
    entry_signal = not na(t) and close < orb_low and rsi < 50 and not first_bar

if strategy_id == "S20 Night Momentum Short"
    entry_signal = not na(n) and (rsi - rsi[3]) < -2 and close < ema21 and hist < 0 and rsi > 35 and rsi < 55


if entry_signal and in_session
    strategy.entry("SE", strategy.short)
if strategy.position_size < 0
    strategy.exit("SE_X", from_entry="SE", profit=tp_pts, loss=sl_pts)
